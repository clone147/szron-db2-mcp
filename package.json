{
  "name": "szron-db2-mcp",
  "version": "1.0.0",
  "description": "Node.js Model Context Protocol (MCP) server for IBM DB2 with read-write capabilities",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "pkg": "pkg dist/index.js --targets node18-win-x64 --output szron-db2-mcp",
    "pkg-all": "pkg dist/index.js --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output szron-db2-mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ibm-db2",
    "database",
    "typescript",
    "nodejs"
  ],
  "author": "Szron Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ibm_db": "^3.2.4",
    "csv-stringify": "^6.4.5",
    "csv-parse": "^5.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "assets": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "outputPath": "build"
  }
}